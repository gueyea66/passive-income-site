<%- include('partials/header') %>

<div class="container">
    <article class="article-detail">
        <header class="article-header">
            <div class="article-meta">
                <a href="/category/<%= article.category.toLowerCase().replace(/ /g, '-').normalize('NFD').replace(/[\u0300-\u036f]/g, '') %>" class="category-badge"><%= article.category %></a>
                <span class="read-time">⏱️ <%= article.readTime %></span>
            </div>
            <h1><%= article.title %></h1>
            <div class="article-info">
                <span class="author">✍️ Par <%= article.author %></span>
                <span class="date">📅 <%= new Date(article.date).toLocaleDateString('fr-FR', { year: 'numeric', month: 'long', day: 'numeric' }) %></span>
            </div>
            <div class="article-tags">
                <% article.tags.forEach(tag => { %>
                    <span class="tag">#<%= tag %></span>
                <% }); %>
            </div>
        </header>

        <!-- Top Article Ad -->
        <div class="ad-container ad-article-top">
            <ins class="adsbygoogle"
                 style="display:block"
                 data-ad-client="ca-pub-XXXXXXXXXX"
                 data-ad-slot="XXXXXXXXXX"
                 data-ad-format="horizontal"
                 data-full-width-responsive="true"></ins>
            <script>(adsbygoogle = window.adsbygoogle || []).push({});</script>
        </div>

        <div class="article-layout">
            <div class="article-content">
                <%- article.content %>

                <!-- Mid Article Ad -->
                <div class="ad-container ad-article-mid">
                    <ins class="adsbygoogle"
                         style="display:block"
                         data-ad-client="ca-pub-XXXXXXXXXX"
                         data-ad-slot="XXXXXXXXXX"
                         data-ad-format="fluid"></ins>
                    <script>(adsbygoogle = window.adsbygoogle || []).push({});</script>
                </div>

                <div class="article-footer-section">
                    <div class="share-section">
                        <h3>Partager cet article</h3>
                        <div class="share-buttons">
                            <a href="https://www.facebook.com/sharer/sharer.php?u=<%= encodeURIComponent('https://yoursite.com/article/' + article.slug) %>" target="_blank" class="share-btn facebook">📘 Facebook</a>
                            <a href="https://twitter.com/intent/tweet?url=<%= encodeURIComponent('https://yoursite.com/article/' + article.slug) %>&text=<%= encodeURIComponent(article.title) %>" target="_blank" class="share-btn twitter">🐦 Twitter</a>
                            <a href="https://www.linkedin.com/shareArticle?mini=true&url=<%= encodeURIComponent('https://yoursite.com/article/' + article.slug) %>" target="_blank" class="share-btn linkedin">💼 LinkedIn</a>
                            <a href="https://wa.me/?text=<%= encodeURIComponent(article.title + ' https://yoursite.com/article/' + article.slug) %>" target="_blank" class="share-btn whatsapp">💬 WhatsApp</a>
                        </div>
                    </div>
                </div>
            </div>

            <aside class="article-sidebar">
                <!-- Sidebar Ad -->
                <div class="ad-container ad-sidebar sticky">
                    <ins class="adsbygoogle"
                         style="display:block"
                         data-ad-client="ca-pub-XXXXXXXXXX"
                         data-ad-slot="XXXXXXXXXX"
                         data-ad-format="vertical"></ins>
                    <script>(adsbygoogle = window.adsbygoogle || []).push({});</script>
                </div>
            </aside>
        </div>

        <!-- Related Articles -->
        <% if (relatedArticles.length > 0) { %>
            <section class="related-articles">
                <h2>Articles Similaires</h2>
                <div class="articles-grid">
                    <% relatedArticles.forEach(related => { %>
                        <article class="article-card">
                            <div class="article-meta">
                                <span class="category-badge"><%= related.category %></span>
                                <span class="read-time">⏱️ <%= related.readTime %></span>
                            </div>
                            <h3><a href="/article/<%= related.slug %>"><%= related.title %></a></h3>
                            <p class="article-excerpt"><%= related.excerpt %></p>
                            <a href="/article/<%= related.slug %>" class="read-more">Lire la suite →</a>
                        </article>
                    <% }); %>
                </div>
            </section>
        <% } %>

        <!-- Bottom Article Ad -->
        <div class="ad-container ad-article-bottom">
            <ins class="adsbygoogle"
                 style="display:block"
                 data-ad-client="ca-pub-XXXXXXXXXX"
                 data-ad-slot="XXXXXXXXXX"
                 data-ad-format="horizontal"
                 data-full-width-responsive="true"></ins>
            <script>(adsbygoogle = window.adsbygoogle || []).push({});</script>
        </div>
    </article>
</div>

<%- include('partials/footer') %>